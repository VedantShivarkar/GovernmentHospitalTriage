# Gemini API (get from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio (get from console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Email (Gmail App Password)
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_16_char

# Demo email for WhatsApp notifications
WHATSAPP_DEMO_EMAIL=demo@hospital.com

# Firebase (path to service account JSON)
FIREBASE_CREDENTIALS=firebase-credentials.json